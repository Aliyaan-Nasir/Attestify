# ─── Attestify Frontend Configuration ─────────────────────────────────────────

# Base URL of the Attestify Indexer REST API (used by the frontend to fetch
# schemas, attestations, and authorities). Defaults to http://localhost:3001/api
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001/api

# Base URL of the Attestify AI Agent server (used by the Agent Chat page).
# Defaults to http://localhost:3002
NEXT_PUBLIC_AGENT_URL=http://localhost:3002
