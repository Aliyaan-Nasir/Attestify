# ─── Hedera Mirror Node ───────────────────────────────────────────────────────
# REST API base URL for polling contract event logs
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# ─── Contract Addresses (populated after deployment) ─────────────────────────
# EVM addresses of deployed contracts on Hedera testnet
SCHEMA_REGISTRY_ADDRESS=0x8320Ae819556C449825F8255e92E7e1bc06c2e80
ATTESTATION_SERVICE_ADDRESS=0xce573F82e73F49721255088C7b4D849ad0F64331

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma ORM
DATABASE_URL=postgresql://user:password@localhost:5432/attestify

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express REST API listens on
PORT=3001

# Interval (ms) between Mirror Node polling cycles (default: 5000)
POLLING_INTERVAL_MS=5000

# ─── HCS Audit Logging (optional) ────────────────────────────────────────────
# Hedera account credentials for submitting HCS messages
HEDERA_ACCOUNT_ID=0.0.XXXXX
HEDERA_PRIVATE_KEY=your-ecdsa-private-key-hex

# HCS Topic IDs (created via: npx tsx scripts/create-hcs-topics.ts)
HCS_TOPIC_SCHEMAS=0.0.XXXXX
HCS_TOPIC_ATTESTATIONS=0.0.XXXXX
HCS_TOPIC_AUTHORITIES=0.0.XXXXX
