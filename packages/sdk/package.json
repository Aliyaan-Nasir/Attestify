{
  "name": "@attestify/sdk",
  "version": "0.1.2",
  "description": "Attestify SDK — TypeScript SDK for the Hedera attestation protocol",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.mjs",
      "require": "./dist/ai.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "lint:ts": "tsc --noEmit --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "ethers": "^6.13.4",
    "@hashgraph/sdk": "^2.55.0"
  },
  "peerDependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.4.0",
    "langchain": "^0.3.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": { "optional": true },
    "@langchain/openai": { "optional": true },
    "langchain": { "optional": true },
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.4.0",
    "langchain": "^0.3.0",
    "zod": "^3.23.0",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4",
    "fast-check": "^3.23.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "attestify",
    "attestation",
    "hedera",
    "hcs",
    "hts",
    "sdk",
    "web3"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aliyaan-Nasir/Attestify.git"
  }
}
