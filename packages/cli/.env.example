# ─── Hedera Testnet Operator Credentials ──────────────────────────────────────
# Required for all CLI commands that submit transactions

# Hedera operator account ID (e.g., 0.0.12345)
HEDERA_ACCOUNT_ID=0.0.xxxxx

# ECDSA private key (hex, without 0x prefix) — used for signing transactions
HEDERA_PRIVATE_KEY=your_ecdsa_private_key_hex
