{
  "name": "@attestify/cli",
  "version": "0.1.5",
  "description": "Attestify CLI — command-line tool for the Hedera attestation protocol",
  "bin": {
    "attestify": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "lint:ts": "tsc --noEmit --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:setup": "tsx src/demos/setup-tokens.ts",
    "demo:native": "tsx src/demos/demo-hedera-native.ts"
  },
  "dependencies": {
    "@attestify/sdk": "workspace:*",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.4.0",
    "langchain": "^0.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4",
    "fast-check": "^3.23.2"
  },
  "keywords": [
    "attestify",
    "hedera",
    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
