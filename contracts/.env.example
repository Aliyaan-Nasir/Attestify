# ─── Hedera Testnet Configuration ─────────────────────────────────────────────
# Required for deployment and contract interaction

# Hedera testnet JSON-RPC relay endpoint
HEDERA_TESTNET_RPC=https://testnet.hashio.io/api

# Hedera operator account ID (e.g., 0.0.12345)
HEDERA_ACCOUNT_ID=0.0.xxxxx

# ECDSA private key (hex, without 0x prefix) — used for deployment and signing
HEDERA_PRIVATE_KEY=your_ecdsa_private_key_hex

# Alias used by Hardhat config (same key, kept for backward compat)
DEPLOYER_PRIVATE_KEY=your_ecdsa_private_key_hex

# ─── Optional: Deployment Configuration ───────────────────────────────────────

# TokenGatedResolver: HTS token address to gate attestations
# TOKEN_ADDRESS=0x0000000000000000000000000000000000000001

# TokenGatedResolver: minimum token balance required
# MINIMUM_BALANCE=1

# FeeResolver: fee in wei (1 HBAR = 1000000000000000000)
# FEE_AMOUNT=1000000000000000000

# ─── Optional: Gas Reporting ──────────────────────────────────────────────────
REPORT_GAS=false
