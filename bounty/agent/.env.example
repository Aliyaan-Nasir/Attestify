# Hedera Operator (the agent's own account)
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=your-ecdsa-private-key-hex

# OpenAI (for LangChain agent)
OPENAI_API_KEY=sk-xxxxxxxxxx

# Attestify Indexer URL
INDEXER_URL=http://localhost:3001/api

# HCS-10 Agent Topics (populated after registration)
AGENT_INBOUND_TOPIC_ID=
AGENT_OUTBOUND_TOPIC_ID=

# HCS Audit Topics
HCS_TOPIC_SCHEMAS=0.0.8221945
HCS_TOPIC_ATTESTATIONS=0.0.8221946
HCS_TOPIC_AUTHORITIES=0.0.8221947

# Server
PORT=3002

# HOL Registry Broker (optional — for guarded registry registration)
REGISTRY_BROKER_API_KEY=

# ─── Verification Agent (A2A demo) ───────────────────────────────────────────
# Can reuse the same Hedera account or use a separate one
VERIFY_AGENT_ACCOUNT_ID=
VERIFY_AGENT_PRIVATE_KEY=
VERIFY_AGENT_PORT=3003

# The Attestify Agent's inbound topic (so the Verification Agent can connect)
ATTESTIFY_AGENT_INBOUND_TOPIC_ID=

# ─── A2A Protocol ─────────────────────────────────────────────────────────────
# Base URL for the A2A Agent Card (used in /.well-known/agent.json)
A2A_BASE_URL=http://localhost:3002

# ─── XMTP Protocol (optional) ────────────────────────────────────────────────
# Private key for XMTP messaging. If not set, XMTP is disabled.
# Generate with: npx @xmtp/node-sdk generate-key
XMTP_PRIVATE_KEY=
